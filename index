    <script>
        // Inicializar Iconos Lucide
        lucide.createIcons();

        // Control del menú móvil desplegable
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Cerrar menú móvil al hacer click en un enlace
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // Control del Header al hacer scroll
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 50) {
                header.classList.add('py-1', 'shadow-2xl', 'bg-wolves-dark/95');
                header.classList.remove('py-3');
            } else {
                header.classList.remove('py-1', 'shadow-2xl', 'bg-wolves-dark/95');
                header.classList.add('py-3');
            }
        });

        // Control Interactividad de Formulario de Contacto
        const contactForm = document.getElementById('contact-form');
        const feedbackDiv = document.getElementById('form-feedback');

        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Simular envío exitoso
            feedbackDiv.classList.remove('hidden', 'bg-red-500/10', 'text-red-400', 'border-red-500/30');
            feedbackDiv.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border', 'border-emerald-500/30');
            feedbackDiv.innerHTML = `
                <div class="flex items-center justify-center gap-2">
                    <i data-lucide="check-circle" class="w-5 h-5 text-emerald-400"></i>
                    <span>¡Solicitud enviada con éxito! Nos comunicaremos contigo en menos de 24 horas.</span>
                </div>
            `;
            lucide.createIcons(); // Volver a renderizar el icono de éxito
            
            // Limpiar formulario
            contactForm.reset();
            
            // Ocultar mensaje tras 5 segundos
            setTimeout(() => {
                feedbackDiv.classList.add('hidden');
            }, 6000);
        });
    </script>
